DATABASE_URL=postgresql://user:password@localhost:5432/goldriseai
# If your password contains reserved URL characters such as % or @,
# either percent-encode them or let the app normalize them automatically.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-real-password
SMTP_FROM=Goldrise AI <no-reply@example.com>
CONTACT_RECIPIENT_EMAIL=info@goldrise.ai
